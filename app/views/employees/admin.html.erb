<div class="w-full max-w-6xl">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-800">จัดการข้อมูลพนักงาน</h1>
    </div>
    <a href="<%= new_employee_path %>" class="btn shadow hover:shadow-md transition text-white">เพิ่มพนักงานใหม่</a>
  </div>

  <% if notice %>
    <div class="alert alert-success mb-4" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="overflow-x-auto shadow-md rounded-lg border border-slate-300">
    <table class="w-full border-collapse">
      <thead>
        <tr style="background: linear-gradient(135deg, #829CBC 0%, #6b7fa3 100%);">
          <th class="px-8 py-5 text-left text-sm font-bold text-white uppercase tracking-widest">ชื่อ</th>
          <th class="px-8 py-5 text-left text-sm font-bold text-white uppercase tracking-widest">ตำแหน่ง</th>
          <th class="px-8 py-5 text-left text-sm font-bold text-white uppercase tracking-widest">เงินเดือน</th>
          <th class="px-8 py-5 text-left text-sm font-bold text-white uppercase tracking-widest">การดำเนินการ</th>
        </tr>
      </thead>
      <tbody>
        <% @employees.each_with_index do |employee, index| %>
          <tr class="<%= index.even? ? 'bg-white' : 'bg-slate-50' %> border-b border-slate-200 hover:bg-slate-100 transition" data-employee-id="<%= employee.id %>">
            <td class="px-6 py-4 text-sm font-medium text-slate-800"><%= employee.name %></td>
            <td class="px-6 py-4 text-sm text-slate-700"><%= employee.position %></td>
            <td class="px-6 py-4 text-sm font-semibold text-emerald-700"><%= number_to_currency(employee.salary.to_i, unit: "฿") %></td>
            <td class="px-6 py-4 text-sm flex gap-2">
              <%= link_to "แก้ไข", edit_employee_path(employee), class: "btn btn-sm text-white" %>
              <button type="button" class="btn btn-sm btn-error delete-btn" data-id="<%= employee.id %>">ลบ</button>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @employees.empty? %>
    <div class="alert alert-info mt-4">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <span>ยังไม่มีข้อมูลพนักงาน</span>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('click', async (e) => {
    if (e.target.classList.contains('delete-btn')) {
      const id = e.target.dataset.id;
      if (!id || isNaN(id)) {
        alert('ไม่พบรหัสพนักงาน');
        return;
      }
      
      if (!confirm('คุณแน่ใจว่าต้องการลบพนักงานคนนี้หรือไม่?')) {
        return;
      }
      
      try {
        const response = await fetch(`/employees/${id}`, {
          method: 'DELETE',
          headers: {
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          }
        });
        
        if (response.ok) {
          window.location.href = '/employees/admin';
        } else {
          alert('เกิดข้อผิดพลาด');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('เกิดข้อผิดพลาด');
      }
    }
  });
</script>
